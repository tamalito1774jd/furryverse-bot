# ========================================
# 🔥 FurryVerse Bot - Environment Variables
# ========================================

# ========== DISCORD BOT ==========
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_GUILD_ID=your_guild_id_for_testing

# Bot Prefix (if using prefix commands)
BOT_PREFIX=!

# ========== DATABASE ==========
# MongoDB
MONGODB_URI=mongodb://localhost:27017/furryverse
MONGODB_ATLAS_URI=mongodb+srv://user:password@cluster.mongodb.net/furryverse

# PostgreSQL
POSTGRESQL_URI=postgresql://user:password@localhost:5432/furryverse
POSTGRESQL_URL=postgresql://user:password@host:5432/database

# Redis (para cache)
REDIS_URI=redis://localhost:6379

# ========== API & BACKEND ==========
API_PORT=3000
API_HOST=0.0.0.0
API_URL=http://localhost:3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ========== DASHBOARD/FRONTEND ==========
NEXT_PUBLIC_API_URL=http://localhost:3000
DASHBOARD_PORT=3001
DASHBOARD_URL=http://localhost:3001

# ========== AI SERVICES ==========
# OpenAI
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4

# Hugging Face
HUGGINGFACE_API_KEY=hf_your_token_here

# Google
GOOGLE_API_KEY=your_google_api_key

# ========== MUSIC & MEDIA ==========
# Spotify
SPOTIFY_CLIENT_ID=your_spotify_id
SPOTIFY_CLIENT_SECRET=your_spotify_secret

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key

# ========== PREMIUM & PAYMENTS ==========
# Stripe
STRIPE_API_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Discord Store (si implementas)
PAYMENT_PROVIDER=stripe

# ========== AUTHENTICATION & SECURITY ==========
# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d

# Session
SESSION_SECRET=your_session_secret_key_here

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key

# ========== LOGGING & MONITORING ==========
# Sentry (error tracking)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# Discord Webhook for logs
LOG_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ========== INTEGRATIONS ==========
# Webhooks
WEBHOOK_SECRET=your_webhook_secret

# Email (para notificaciones)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@furryverse.bot

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Telegram Bot (si lo usas)
TELEGRAM_BOT_TOKEN=your_telegram_token

# ========== EXTERNAL SERVICES ==========
# GitHub (para stats)
GITHUB_TOKEN=ghp_your_github_token

# CloudFlare
CLOUDFLARE_API_KEY=your_cloudflare_key
CLOUDFLARE_ZONE_ID=your_zone_id

# ========== DEPLOYMENT ==========
# Para producción
PRODUCTION_URL=https://furryverse-bot.com
PRODUCTION_API_URL=https://api.furryverse-bot.com

# Railway/Heroku
RAILWAY_ENVIRONMENT_ID=prod
DATABASE_URL=postgresql://...

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ========== CACHE ==========
CACHE_TTL=3600
CACHE_TYPE=redis

# ========== DEBUG ==========
DEBUG=false
LOG_LEVEL=info
# DEBUG=furryverse:*

# ========== CUSTOM CONFIG ==========
# Para características específicas
BOT_VERSION=1.0.0
SUPPORT_SERVER_INVITE=https://discord.gg/furryverse
WEBSITE_URL=https://furryverse-bot.com
